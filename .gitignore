# --- IDE & System Files ---
.idea/
.vscode/
*.swp
*.log
.DS_Store
Thumbs.db

# --- Java / Maven (BACKEND) ---
BACKEND/target/
BACKEND/*.jar
BACKEND/*.war
BACKEND/*.ear
BACKEND/.project
BACKEND/.classpath
BACKEND/.settings/
BACKEND/bin/

# --- Node / Angular (FRONTEND) ---
FRONTEND/node_modules/
FRONTEND/dist/
FRONTEND/.angular/
FRONTEND/tmp/
FRONTEND/out-tsc/
FRONTEND/bazel-out/
node_modules/

# --- Python (Agents) ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.env
**/venv/
**/env/
**/.venv/
**/.pytest_cache/
