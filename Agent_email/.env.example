# ─── Application ───────────────────────────────────────────
APP_SECRET_KEY=your-super-secret-key-change-this
APP_HOST=0.0.0.0
APP_PORT=8080

# ─── Groq LLM ──────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Email / IMAP (Zoho Mail) ──────────────────────────────
EMAIL_ADDRESS=your@zohomail.com
EMAIL_PASSWORD=your-zoho-app-password
IMAP_SERVER=imap.zoho.com
IMAP_PORT=993
SMTP_SERVER=smtp.zoho.com
SMTP_PORT=587

# ─── Polling Interval ──────────────────────────────────────
POLL_INTERVAL_MINUTES=5

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./email_agent.db

# ─── Admin Credentials (first run) ─────────────────────────
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123!
