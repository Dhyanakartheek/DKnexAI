# ============================================================
# DKnexAI — Production Environment Variables
# Location on EC2: /opt/dknexai/.env
# Permissions: chmod 600 /opt/dknexai/.env
#
# FILL IN all values marked with <REPLACE_ME> before deploying
# ============================================================

# ── AI API Keys ───────────────────────────────────────────────
GROQ_API_KEY=<REPLACE_ME: your gsk_... key from console.groq.com>
OPENAI_API_KEY=<REPLACE_ME_OR_LEAVE_BLANK>
GEMINI_API_KEY=<REPLACE_ME_OR_LEAVE_BLANK>

# ── MySQL ─────────────────────────────────────────────────────
# These are used by deploy.sh to create the DB automatically
DB_USER=dknexai_user
DB_PASSWORD=<REPLACE_ME: strong password e.g. Dknex@Prod2024!>

# ── Spring Boot JWT ───────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=<REPLACE_ME: 64+ char random hex string>

# ── Agent_email App ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
APP_SECRET_KEY=<REPLACE_ME: 32+ char random hex string>
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=<REPLACE_ME: strong admin password>

# ── Email / IMAP (for Agent_email polling) ────────────────────
EMAIL_ADDRESS=<REPLACE_ME: your zoho or gmail address>
EMAIL_PASSWORD=<REPLACE_ME: app-specific password>
IMAP_SERVER=imap.zoho.com
SMTP_SERVER=smtp.zoho.com

# ── Frontend Origin (for CORS) ────────────────────────────────
FRONTEND_URL=https://yourdomain.com
